import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
import datetime as dt

# Carregando os datasets brutos
# Preciso dessas 3 tabelas para cruzar quem comprou (customers), quando (orders) e quanto (payments)
df_orders = pd.read_csv('olist_orders_dataset.csv')
df_payments = pd.read_csv('olist_order_payments_dataset.csv')
df_customers = pd.read_csv('olist_customers_dataset.csv')

# Passo 1: Notei que a tabela de pagamentos tem várias linhas para o mesmo pedido (parcelas). 
# Vou somar tudo por order_id para ter o valor real gasto em cada compra.
pagamentos_por_pedido = df_payments.groupby('order_id')['payment_value'].sum().reset_index()

# Passo 2: Agora vou unir as tabelas. 
# Uso o 'customer_unique_id' porque ele identifica o CPF/Pessoa, enquanto o 'customer_id' muda a cada pedido.
df_merge = pd.merge(df_orders, pagamentos_por_pedido, on='order_id')
df_rfm_base = pd.merge(df_merge, df_customers, on='customer_id')

# Passo 3: Limpeza e Tipagem.
# Preciso converter as datas, senão o Python entende como texto e não faz cálculos matemáticos.
df_rfm_base['order_purchase_timestamp'] = pd.to_datetime(df_rfm_base['order_purchase_timestamp'])

# --- Visualização de Portfólio ---
# Antes de calcular o RFM, quero ver a distribuição de gastos dos clientes.
plt.figure(figsize=(10, 5))
sns.histplot(df_rfm_base[df_rfm_base['payment_value'] < 500]['payment_value'], bins=50, kde=True, color='teal')
plt.title('Distribuição do Valor dos Pedidos (Até R$ 500)')
plt.xlabel('Valor Pago (R$)')
plt.ylabel('Quantidade de Pedidos')
plt.show()

# Percebi que a grande maioria dos pedidos se concentra abaixo de R$ 200,00. 
# Isso me mostra que o Olist tem um ticket médio mais baixo, o que influencia na segmentação de "Valor".
print(f"Total de registros para análise: {df_rfm_base.shape[0]}")
display(df_rfm_base[['customer_unique_id', 'order_purchase_timestamp', 'payment_value']].head())
