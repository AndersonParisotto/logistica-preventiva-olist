# Criando as notas de 1 a 5 (Scores)

# 1. Recência: Quanto MENOR o número de dias, MELHOR (Nota 5)
# Usei o pd.qcut para dividir a base em 5 grupos iguais (quintis)
rfm['R_Score'] = pd.qcut(rfm['Recencia'], 5, labels=[5, 4, 3, 2, 1])

# 2. Valor: Quanto MAIOR o gasto, MELHOR (Nota 5)
rfm['V_Score'] = pd.qcut(rfm['Valor'], 5, labels=[1, 2, 3, 4, 5])

# 3. Frequência: Como 96% da base é '1', o qcut não funciona bem.
# Criei uma função simples: se comprou 1 vez é nota 1, se comprou 2 é nota 3, mais que isso é 5.
def nota_frequencia(x):
    if x == 1: return 1
    if x == 2: return 3
    return 5

rfm['F_Score'] = rfm['Frequencia'].apply(nota_frequencia)

# Agora crio o RFM_Score final somando as notas ou apenas juntando os números
rfm['RFM_Segment'] = rfm['R_Score'].astype(str) + rfm['F_Score'].astype(str) + rfm['V_Score'].astype(str)

# Percebi que agora cada cliente tem um "código" (Ex: 515 é um cliente recente, comprou 1 vez, mas gastou muito)
display(rfm[['Recencia', 'Frequencia', 'Valor', 'RFM_Segment']].head())
