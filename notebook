# Definindo o ponto de referência para o cálculo de Recência
snapshot_date = df_rfm_base['order_purchase_timestamp'].max() + dt.timedelta(days=1)

# Agrupando por cliente único para calcular as métricas
rfm = df_rfm_base.groupby('customer_unique_id').agg({
    'order_purchase_timestamp': lambda x: (snapshot_date - x.max()).days, # Recência
    'order_id': 'count',                                               # Frequência
    'payment_value': 'sum'                                             # Valor (Monetário)
})

# Renomeando para ficar apresentável no portfólio
rfm.columns = ['Recencia', 'Frequencia', 'Valor']

