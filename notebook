# Refiz o mapeamento para garantir que cada código tenha um nome claro no gráfico
# Foquei no R (Recência) e F (Frequência) para definir o comportamento
def rotular_segmento(df):
    r = int(df['R_Score'])
    f = int(df['F_Score'])
    
    if r >= 4 and f >= 3:
        return 'Campeões / Fiéis'
    if r >= 4 and f == 1:
        return 'Novos Clientes'
    if r == 3:
        return 'Potencialmente Fiéis'
    if r <= 2 and f >= 3:
        return 'Risco de Churn (Alto Valor)'
    if r <= 2 and f == 1:
        return 'Clientes Perdidos / Hibernando'
    return 'Outros'

rfm['Segmento_Nome'] = rfm.apply(rotular_segmento, axis=1)

