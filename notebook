# Carregando a base de reviews
df_reviews = pd.read_csv('olist_order_reviews_dataset.csv')

# Passo 1: Notei que muitos clientes não escrevem comentário, apenas dão nota.
# Vou filtrar apenas quem escreveu algo para a gente ter o que analisar.
df_comentarios = df_reviews.dropna(subset=['review_comment_message']).copy()

# Passo 2: Criando uma lógica simples de sentimento baseada na nota (Score)
# Percebi que notas 4 e 5 são geralmente elogios, enquanto 1 e 2 são críticas pesadas.
def rotular_sentimento(nota):
    if nota >= 4: return 'Positivo'
    if nota == 3: return 'Neutro'
    return 'Negativo'

df_comentarios['Sentimento'] = df_comentarios['review_score'].apply(rotular_sentimento)

# Passo 3: Vamos ver a distribuição desses sentimentos no portfólio
plt.figure(figsize=(8, 5))
sns.countplot(x='Sentimento', data=df_comentarios, palette='RdYlGn', order=['Negativo', 'Neutro', 'Positivo'])
plt.title('Sentimento dos Comentários dos Clientes')
plt.show()

# Passo 4: Agora o "pulo do gato": O que os clientes negativos estão falando?
# Vou pegar os comentários negativos e ver as palavras que mais aparecem.
from collections import Counter

# Fiz uma limpeza rápida para pegar as palavras mais comuns em comentários negativos
palavras_negativas = " ".join(df_comentarios[df_comentarios['Sentimento'] == 'Negativo']['review_comment_message']).lower()
top_palavras = Counter(palavras_negativas.split()).most_common(10)

print("Palavras mais comuns em críticas:")
for palavra, freq in top_palavras:
    if len(palavra) > 3: # Filtrei palavras pequenas (artigos, preposições)
        print(f"- {palavra}: {freq} vezes")

# Percebi que palavras como "atraso", "entrega" e "produto" costumam dominar.
